# Database (RDS PostgreSQL)
DB_HOST=<rds-endpoint>
DB_PORT=5432
DB_NAME=expensetracker
DB_USER=dbadmin
DB_PASSWORD=<your-db-password>
DB_DIALECT=postgres

# Auth
JWT_SECRET=<your-jwt-secret>

# URLs (use ALB DNS for deployed, localhost for local dev)
BACKEND_URL=http://<alb-dns-name>
FRONTEND_URL=http://<s3-website-endpoint>

# Email (nodemailer - use an app password, not your account password)
EMAIL_USERNAME=<your-email@example.com>
EMAIL_PASSWORD=<your-app-password>
